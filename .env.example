# Vercel KV — set these via Vercel dashboard or `vercel env pull`
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Absolute site URL — used so share-card images unfurl on WhatsApp/social.
# e.g. https://your-domain.com  (no trailing slash)
NEXT_PUBLIC_SITE_URL=

# RSVP feature toggle. Disabled by default — the RSVP section is hidden and
# POST /api/rsvp returns 404. Set to 'true' to show the form and accept
# submissions. Applied at build time (NEXT_PUBLIC_* is inlined).
NEXT_PUBLIC_RSVP_ENABLED=false

# Color theme: any id registered in lib/themes.ts — currently 'dark' (default)
# or 'light' (warm ivory, higher-contrast text). Unknown values fall back to dark.
# Applied at build time; the opening envelope stays dark in both themes.
NEXT_PUBLIC_THEME=dark
